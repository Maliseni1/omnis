{
  "name": "omnis-desktop",
  "private": true,
  "version": "0.1.1",
  "main": "dist-electron/main.js",
  "author": {
    "name": "Chiza Labs",
    "email": "chizalabs@gmail.com"
  },
  "description": "Universal File Ecosystem",
  "homepage": "https://github.com/maliseni1/omnis",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "pnpm build && electron-builder --linux"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "html-to-docx": "^1.8.0",
    "lucide-react": "^0.555.0",
    "mammoth": "^1.11.0",
    "pdfjs-dist": "4.4.168",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-pdf": "^9.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "electron": "^39.2.4",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.chizalabs.omnis",
    "productName": "Omnis",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "build/icon.png",
      "build/icons/**/*"
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Office",
      "maintainer": "Chiza Labs <chizalabs@gmail.com>",
      "icon": "build/icons",
      "executableName": "omnis",
      "synopsis": "Universal File Ecosystem",
      "description": "A comprehensive file management and editing application",
      "asar": false,
      "desktop": {
        "StartupWMClass": "Omnis"
      }
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libappindicator3-1",
        "libsecret-1-0"
      ]
    },
    "extraResources": [
      {
        "from": "build/icons/",
        "to": "build/icons/",
        "filter": ["**/*"]
      }
    ]
  }
}